rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Test Connection Path
    match /test/connection {
      allow get: if true;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Chat Validation
    function isValidChat(data) {
      return data.userId == request.auth.uid &&
             (data.get('model', '') is string && data.get('model', '').size() <= 100) &&
             (data.get('title', '') is string && data.get('title', '').size() <= 500);
    }

    match /chats/{chatId} {
      // Create: Match UID and server timestamps
      allow create: if isSignedIn() && 
                      isValidChat(incoming()) &&
                      incoming().keys().hasAll(['userId', 'createdAt', 'updatedAt', 'model']) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      
      // Get: Owner only
      allow get: if isSignedIn() && isOwner(existing().userId);
      
      // List: SECURE LIST (Pillar 8)
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Update: Action-Based Pattern (Pillar 4)
      allow update: if isSignedIn() && isOwner(existing().userId) &&
                      incoming().updatedAt == request.time &&
                      (
                        // Action: Update Title
                        incoming().diff(existing()).affectedKeys().hasAny(['title', 'updatedAt']) ||
                        // Action: Update Settings
                        incoming().diff(existing()).affectedKeys().hasAny(['model', 'temperature', 'maxTokens', 'updatedAt'])
                      );
      
      allow delete: if isSignedIn() && isOwner(existing().userId);

      // 2. Message Validation
      function isValidMessage(data) {
        return (data.get('role', '') in ['user', 'model']) &&
               (data.get('content', '') is string && data.get('content', '').size() <= 100000);
      }

      match /messages/{messageId} {
        // Relational Sync (Pillar 1): Check parent chat ownership
        function getChatOwnerId() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.userId;
        }

        allow create: if isSignedIn() && getChatOwnerId() == request.auth.uid &&
                        isValidMessage(incoming()) &&
                        incoming().keys().hasAll(['role', 'content', 'createdAt']) &&
                        incoming().createdAt == request.time;
        
        allow update: if isSignedIn() && getChatOwnerId() == request.auth.uid &&
                        // Allow updating content (for streaming AI response)
                        incoming().diff(existing()).affectedKeys().hasOnly(['content']) &&
                        incoming().content is string && incoming().content.size() <= 100000;
        
        allow list, get: if isSignedIn() && getChatOwnerId() == request.auth.uid;
        
        allow delete: if isSignedIn() && getChatOwnerId() == request.auth.uid;
      }
    }
  }
}
